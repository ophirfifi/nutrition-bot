# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Random secret string — protects the webhook endpoint
TELEGRAM_WEBHOOK_SECRET=change_me_to_random_secret_32chars

# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase ───────────────────────────────────────────────
# For LOCAL DEV: path to downloaded service account JSON
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# For RAILWAY (set one of these, Railway prefers env vars):
# Base64-encode your JSON: base64 -i firebase-service-account.json
FIREBASE_CREDENTIALS_BASE64=

# Firebase project ID (visible in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-project-id

# ─── Hosting ────────────────────────────────────────────────
# Your Railway backend public URL (no trailing slash)
WEBHOOK_BASE_URL=https://your-backend.up.railway.app

# ─── Dashboard ──────────────────────────────────────────────
# URL of backend API, used by Next.js dashboard
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# ─── App ────────────────────────────────────────────────────
DEBUG=false
